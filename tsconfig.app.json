{
  "extends": "./tsconfig.json",
  "typedocOptions": {
    "entryPoints": [
      "src"
    ],
    "entryPointStrategy": "expand",
    "out": "docs/tsdoc",
    "exclude": [
      "**/*.spec.ts",
      "**/*.test.ts"
    ]
  },
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "rootDir": "./src",
    "types": []
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}
